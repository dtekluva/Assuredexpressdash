# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# In Docker, DB_HOST and DB_PORT are overridden by docker-compose environment
DB_NAME=assured_express
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
# In Docker, overridden by docker-compose environment
REDIS_URL=redis://localhost:6379

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── AXpress Main Backend (service-to-service auth) ───────────────────────────
AXPRESS_BASE_URL=http://localhost:8000
AXPRESS_SERVICE_KEY=sk_paste-your-key-here

# ── APEX AI Coach ────────────────────────────────────────────────────────────
# Provider: "anthropic" or "openai"
COACH_LLM_PROVIDER=anthropic
COACH_MODEL=claude-sonnet-4-20250514
COACH_ANTHROPIC_API_KEY=
COACH_OPENAI_API_KEY=

# ── Termii (SMS / WhatsApp — Nigerian gateway) ──────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=AssuredExp

# ── SendGrid (Email) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=ops@assuredexpress.ng

# ── Firebase (Rider in-app push notifications) ──────────────────────────────
FIREBASE_CREDENTIALS_JSON=
    